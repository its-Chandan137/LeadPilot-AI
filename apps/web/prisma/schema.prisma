generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String            @id @default(cuid())
  email      String            @unique
  name       String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  workspaces WorkspaceMember[]
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  members   WorkspaceMember[]
  projects  Project[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        Role      @default(MEMBER)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Project {
  id            String             @id @default(cuid())
  workspaceId   String
  name          String
  siteUrl       String
  clientId      String             @unique @default(cuid())
  widgetConfig  Json               @default("{}")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  workspace     Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  voiceConversations VoiceConversation[]
  leads         Lead[]
  sources       KnowledgeSource[]
  chunks        KnowledgeChunk[]
  traffic       WidgetTraffic[]
}

model WidgetTraffic {
  id             String   @id @default(cuid())
  projectId      String
  visitorId      String?
  referrer       String? // raw document.referrer (capped at 500 chars)
  referrerDomain String? // normalizeReferrerDomain(); null = Direct/none
  path           String? // embed-page pathname (capped at 300 chars)
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([projectId, referrerDomain])
}

model Conversation {
  id        String    @id @default(cuid())
  projectId String
  visitorId String
  createdAt DateTime  @default(now())
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Lead {
  id             String      @id @default(cuid())
  projectId      String
  visitorId      String
  conversationId String
  name           String?
  email          String?
  phone          String?
  score          LeadScore   @default(COLD)
  status         LeadStatus  @default(NEW)
  source         LeadSource  @default(CHAT)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, visitorId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MessageRole {
  USER
  ASSISTANT
}

enum LeadScore {
  HOT
  WARM
  COLD
  SPAM
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum LeadSource {
  CHAT
  FORM
  MANUAL
}

model KnowledgeSource {
  id        String        @id @default(cuid())
  projectId String
  type      SourceType
  name      String
  content   String        @db.Text
  status    SourceStatus  @default(PROCESSING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chunks    KnowledgeChunk[]
}

model KnowledgeChunk {
  id        String          @id @default(cuid())
  projectId String
  sourceId  String
  content   String          @db.Text
  embedding Unsupported("vector(3072)")?
  metadata  Json            @default("{}")
  createdAt DateTime        @default(now())
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source    KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

enum SourceType {
  TEXT
  DOCUMENT
  URL
  SOCIAL
}

enum SourceStatus {
  PROCESSING
  READY
  FAILED
}

model VoiceConversation {
  id         String         @id @default(cuid())
  projectId  String
  visitorId  String
  roomName   String         @unique
  duration   Int?
  status     String         @default("active")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages   VoiceMessage[]
}

model VoiceMessage {
  id                 String            @id @default(cuid())
  voiceConversationId String
  role               String
  content            String
  createdAt          DateTime          @default(now())
  voiceConversation  VoiceConversation @relation(fields: [voiceConversationId], references: [id], onDelete: Cascade)
}

// --- Durable Intelligence Persistence (replaces in-memory Maps) -----------
// ConversationId is the shared relationship key. We never duplicate the base
// Conversation / Lead tables — these models only hold AI-generated intelligence.

model ConversationIntelligence {
  conversationId String   @id
  projectId      String?
  data           Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
}

model LeadProfile {
  conversationId String   @id
  projectId      String?
  data           Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
}

model BusinessProfile {
  conversationId String   @id
  projectId      String?
  data           Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
}

model AnalyticsSnapshot {
  conversationId String   @id
  projectId      String?
  data           Json
  updatedAt      DateTime @updatedAt

  @@index([projectId])
}

model TimelineEvent {
  id            String   @id @default(cuid())
  conversationId String
  projectId     String?
  event         String
  description   String
  category      String
  importance    Int      @default(1)
  timestamp     DateTime
  createdAt     DateTime @default(now())

  @@unique([conversationId, event, description])
  @@index([conversationId])
  @@index([projectId])
}
